{
  "manifest_version": 3,
  "name": "Invoice Helper",
  "version": "0.2.0",
  "description": "Manifest V3 Chrome extension with extract/fill workflow and local debug logging.",
  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.telioservices.hr/PrisonLevelInvoiceReport/*",
    "https://digitalneusluge.fina.hr/eRacunB2B/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Invoice Helper",
    "default_popup": "popup.html"
  }
}
